{
  "name": "eriksiemund/kirby-mux",
  "description": "Upload videos to MUX from the Kirby CMS panel. @forked from robinscholz/kirby-mux and dev-ofty/kirby-mux",
  "type": "kirby-plugin",
  "keywords": [
    "kirby",
    "mux",
    "video",
    "stream"
  ],
  "license": "MIT",
  "homepage": "https://github.com/eriksiemund/kirby-mux#readme",
  "authors": [
    {
      "name": "Erik Siemund",
      "email": "mail@eriksiemund.com",
      "homepage": "https://eriksiemund.com"
    }
  ],
  "require": {
    "php": ">=8.1.0",
    "getkirby/composer-installer": "^1.2",
    "muxinc/mux-php": "^5.0",
    "vlucas/phpdotenv": "^5.4",
    "james-heinrich/getid3": "^1.9"
  },
  "autoload": {
    "psr-4": {
      "KirbyMux\\": "classes/KirbyMux/"
    }
  },
  "scripts": {
    "dist": "composer install --no-dev --optimize-autoloader"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  }
}
